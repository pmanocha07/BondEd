generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  student
  alumni
}

enum ConnectionStatus {
  pending
  accepted
  declined
}

model User {
  id            String       @id @default(cuid())
  email         String       @unique
  passwordHash  String
  role          Role
  createdAt     DateTime     @default(now())
  profile       Profile?
  sentRequests  Connection[] @relation("StudentConnections")
  receivedRequests Connection[] @relation("AlumniConnections")
}

model Profile {
  id         String   @id @default(cuid())
  userId     String   @unique
  fullName   String
  gradYear   Int
  domain     String
  interests  String[]
  bio        String
  company    String?
  jobTitle   String?
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Connection {
  id         String            @id @default(cuid())
  studentId  String
  alumniId   String
  status     ConnectionStatus  @default(pending)
  createdAt  DateTime          @default(now())
  student    User              @relation("StudentConnections", fields: [studentId], references: [id], onDelete: Cascade)
  alumni     User              @relation("AlumniConnections", fields: [alumniId], references: [id], onDelete: Cascade)

  @@unique([studentId, alumniId])
}